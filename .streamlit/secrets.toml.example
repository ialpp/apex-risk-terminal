# Apex Risk Terminal — Streamlit Cloud Deployment Notes
# Bu dosya projenin dağıtım ayarlarını belgelemek için oluşturulmuştur.
# Gerçek secrets (API key, şifre) buraya YAZILMAMALIDIR.
# Streamlit Cloud > App Settings > Secrets bölümüne eklenmelidir.
#
# Bu dosyayı secrets.toml olarak kopyalayıp değerlerinizi doldurun:
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# ⚠️ secrets.toml .gitignore'da bulunur — commit etmeyin!

# ─── Demo Kullanıcı Şifrelerini Override Et ──────────────────────
# Boş bırakılırsa default fallback şifreler kullanılır.
# Production deploy için mutlaka güçlü şifreler girin.
[demo_users]
admin_password   = "admin123"          # Değiştirin!
analyst_password = "analist123"        # Değiştirin!
mudur_password   = "mudur123"          # Değiştirin!
stajyer_password = "stajyer123"        # Değiştirin!

# ─── Opsiyonel: API Entegrasyonları ─────────────────────────────
# [api_keys]
# openai_api_key     = "sk-..."
# alpha_vantage_key  = "..."
# fred_api_key       = "..."
